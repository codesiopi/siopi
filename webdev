<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Web Development</title>

<style>

*{
  box-sizing:border-box;
}

body{
  margin:0;
  font-family:-apple-system, BlinkMacSystemFont, "Segoe UI",
  Roboto, Helvetica, Arial, sans-serif;
  background:#7fb3d5; /* background biru */
  display:flex;
  justify-content:center;
}

/* container */
.page{
  width:100%;
  max-width:420px;
  min-height:100vh;
  padding:20px;
}

/* card utama biru */
.card{
  background:#7fb3d5;
  border-radius:36px;
  padding:26px 18px 30px;
}

/* item putih */
.item{
  background:#ffffff;
  border-radius:22px;
  padding:18px;
}

.item h3{
  margin:0 0 6px;
  font-size:18px;
  font-weight:800;
  color:#111;
}

.item p{
  margin:0;
  font-size:14px;
  line-height:1.6;
  color:#444;
}

</style>
</head>

<body>

<div class="page">
  <div class="card">

    <div class="item">
      <h3>💻 Web Development</h3>
      <p>
        Jalur untuk membangun website profesional dan skill web dari dasar.
      </p>
    </div>

  </div>
</div>

</body>
</html>
